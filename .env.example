# ======================
# CyberStudy AI Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub
# ======================

# ── Backend ─────────────────────────────────────
API_KEY=supersecretkey_change_this_in_production_2026
DATA_PATH=/app/backend/data/docs
DB_PATH=/app/backend/data/chroma
EMBED_MODEL=mxbai-embed-large
LLM_MODEL=llama3.2
OLLAMA_HOST=http://ollama:11434

# ── Frontend ────────────────────────────────────
BACKEND_URL=http://backend:8000
# API_KEY is read from the same value above (docker-compose passes it)

# ── Optional (for production hardening) ────────
# MAX_FILE_SIZE=15728640   # 15MB in bytes (already hardcoded but can override)